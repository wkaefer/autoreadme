#!/bin/ksh93
# Preprocess a file or stdin before feeding it into markdown.
# Adds HTML markup for syntax highlighting based on line prefixes.
# Also handles optional form feed markers (@@) and feeds the result into markdown_py if available.

# Reference Markdown links:
# https://daringfireball.net/projects/markdown/
# https://python-markdown.github.io/
# https://commonmark.org/

# Input handling
if [[ -n "$1" ]]; then
  if [[ -f "$1" ]]; then
    exec < "$1"
  else
    print "Missing file: $1" >&2
    exit 1
  fi
fi

# Strip Markdown Comments
# ------------------------
# Sometimes lines with [...]: # might get identified as a comment
# within markdown, but now Always.
# So this bit is to strip lines beginning with '[#' as well.
grep -v '^\[#' |

# Highlight rules (from txt2html, HighlightText)
# @- gray, @+ cyan, @g green, @b blue, @p purple, @y yellow, @r red, @o orange
# @@ form feed (page break)

sed \
  -e 's,^@-\(.*\)$,<mark class="gray">\1</mark>,' \
  -e 's,^@+\(.*\)$,<mark class="cyan">\1</mark>,' \
  -e 's,^@g\(.*\)$,<mark class="green">\1</mark>,' \
  -e 's,^@b\(.*\)$,<mark class="blue">\1</mark>,' \
  -e 's,^@p\(.*\)$,<mark class="purple">\1</mark>,' \
  -e 's,^@y\(.*\)$,<mark class="yellow">\1</mark>,' \
  -e 's,^@r\(.*\)$,<mark class="red">\1</mark>,' \
  -e 's,^@o\(.*\)$,<mark class="orange">\1</mark>,' | \
# Inline @X{...} highlights — encode as placeholders that survive markdown escaping
sed \
  -e 's,@-{\([^}]*\)},ZZMKgrayZZ\1ZZMKENDZ,g' \
  -e 's,@+{\([^}]*\)},ZZMKcyanZZ\1ZZMKENDZ,g' \
  -e 's,@g{\([^}]*\)},ZZMKgreenZZ\1ZZMKENDZ,g' \
  -e 's,@b{\([^}]*\)},ZZMKblueZZ\1ZZMKENDZ,g' \
  -e 's,@p{\([^}]*\)},ZZMKpurpleZZ\1ZZMKENDZ,g' \
  -e 's,@y{\([^}]*\)},ZZMKyellowZZ\1ZZMKENDZ,g' \
  -e 's,@r{\([^}]*\)},ZZMKredZZ\1ZZMKENDZ,g' \
  -e 's,@o{\([^}]*\)},ZZMKorangeZZ\1ZZMKENDZ,g' | \
sed \
  -e 's,^@@\(.*\)$,<div style="page-break-after: always;">\1</div>,' |

# Allow markdown to include another file (single level)
awk '$1 != "#include" { print($0) } $1 == "#include" && $2 !~ /examplefile.html/ { system("cat " $2) }' |

# Run through markdown converter if available
if whence markdown_py >/dev/null; then
  print '<!-- ******🟩** Generated by markdown_py **🟩*************** -->'
  markdown_py --encoding utf-8 -x extra |
    # Mermaid
    # -------
    awk '
        BEGIN { in_mermaid = 0; mermaid_included = 0; }
        # Match mermaid start block
        /^<pre><code class="language-mermaid">/ {
            if ( mermaid_included == 0 ) {
                print("<script src=\x27/.js/mermaid.min.js\x27></script>")
                print("<script>")
                print("  mermaid.initialize({ startOnLoad: true })")
                print("</script>")
                mermaid_included = 1;
            }
            sub(/^<pre><code class="language-mermaid">/, "<pre><code><div class=\"mermaid\">")
            print
            in_mermaid = 1
            next
        }
        # Match end block
        /^<\/code><\/pre>/ {
            if (in_mermaid) {
                print "</div>" $0
                in_mermaid = 0
                next
            }
        }
        # Default: print unchanged
        { print }' |
    # Restore inline @X{...} placeholders to <mark> tags
    sed \
      -e 's,ZZMKgrayZZ,<mark class="gray">,g' \
      -e 's,ZZMKcyanZZ,<mark class="cyan">,g' \
      -e 's,ZZMKgreenZZ,<mark class="green">,g' \
      -e 's,ZZMKblueZZ,<mark class="blue">,g' \
      -e 's,ZZMKpurpleZZ,<mark class="purple">,g' \
      -e 's,ZZMKyellowZZ,<mark class="yellow">,g' \
      -e 's,ZZMKredZZ,<mark class="red">,g' \
      -e 's,ZZMKorangeZZ,<mark class="orange">,g' \
      -e 's,ZZMKENDZ,</mark>,g' |
    # Emoji width fix for <pre> blocks
    # ---------------------------------
    # Wrap emoji inside <pre><code> in <span class="emoji"> so CSS
    # can constrain them to 2ch, preventing box-drawing skew.
    python3 -c '
import sys, re
_EMOJI = re.compile(
    "(["
    "\U0001F600-\U0001F64F"
    "\U0001F300-\U0001F5FF"
    "\U0001F680-\U0001F6FF"
    "\U0001F900-\U0001F9FF"
    "\U0001FA00-\U0001FA6F"
    "\U0001FA70-\U0001FAFF"
    "\U00002702-\U000027B0"
    "\U000023F0-\U000023FA"
    "\U0000231A-\U0000231B"
    "\U000025AA-\U000025FE"
    "\U00002600-\U000026FF"
    "\U00002934-\U00002935"
    "\U00003030\U0000303D"
    "\U00003297\U00003299"
    "\U0000200D"
    "\U0000FE0F"
    "]+)",
    re.UNICODE,
)
inside = False
for line in sys.stdin:
    if "<pre><code>" in line:
        inside = True
    if inside:
        line = _EMOJI.sub(r'"'"'<span class="emoji">\1</span>'"'"', line)
    if "</code></pre>" in line:
        inside = False
    sys.stdout.write(line)
'

else
    cat
fi
