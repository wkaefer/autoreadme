#!/bin/ksh93
# Preprocess a file or stdin before feeding it into markdown.
# Adds HTML markup for syntax highlighting based on line prefixes.
# Also handles optional form feed markers (@@) and feeds the result into markdown_py if available.

# Reference Markdown links:
# https://daringfireball.net/projects/markdown/
# https://python-markdown.github.io/
# https://commonmark.org/

# Input handling
if [[ -n "$1" ]]; then
  if [[ -f "$1" ]]; then
    exec < "$1"
  else
    print "Missing file: $1" >&2
    exit 1
  fi
fi

# Strip Markdown Comments
# ------------------------
# Sometimes lines with [...]: # might get identified as a comment
# within markdown, but now Always.
# So this bit is to strip lines beginning with '[#' as well.
grep -v '^\[#' |

# Highlight rules (from txt2html, HighlightText)
# @- gray, @+ cyan, @g green, @b blue, @p purple, @y yellow, @r red, @o orange
# @@ form feed (page break)

sed \
  -e 's,^@-\(.*\)$,<mark class="gray">\1</mark>,' \
  -e 's,^@+\(.*\)$,<mark class="cyan">\1</mark>,' \
  -e 's,^@g\(.*\)$,<mark class="green">\1</mark>,' \
  -e 's,^@b\(.*\)$,<mark class="blue">\1</mark>,' \
  -e 's,^@p\(.*\)$,<mark class="purple">\1</mark>,' \
  -e 's,^@y\(.*\)$,<mark class="yellow">\1</mark>,' \
  -e 's,^@r\(.*\)$,<mark class="red">\1</mark>,' \
  -e 's,^@o\(.*\)$,<mark class="orange">\1</mark>,' | \
sed \
  -e 's,^@@\(.*\)$,<div style="page-break-after: always;">\1</div>,' |

# Allow markdown to include another file (single level)
awk '$1 != "#include" { print($0) } $1 == "#include" && $2 !~ /examplefile.html/ { system("cat " $2) }' |

# Run through markdown converter if available
if whence markdown_py >/dev/null; then
  print '<!-- ******🟩** Generated by markdown_py **🟩*************** -->'
  markdown_py --encoding utf-8 -x extra |
    # Mermaid
    # -------
    awk '
        BEGIN { in_mermaid = 0; mermaid_included = 0; }
        # Match mermaid start block
        /^<pre><code class="language-mermaid">/ {
            if ( mermaid_included == 0 ) {
                print("<script src=\x27/.js/mermaid.min.js\x27></script>")
                print("<script>")
                print("  mermaid.initialize({ startOnLoad: true })")
                print("</script>")
                mermaid_included = 1;
            }
            sub(/^<pre><code class="language-mermaid">/, "<pre><code><div class=\"mermaid\">")
            print
            in_mermaid = 1
            next
        }
        # Match end block
        /^<\/code><\/pre>/ {
            if (in_mermaid) {
                print "</div>" $0
                in_mermaid = 0
                next
            }
        }
        # Default: print unchanged
        { print }' |
    cat

else
    cat
fi
