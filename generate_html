#!/usr/bin/env ksh93

# 🛠️ Script: generate_html
# 📄 Purpose: Process README.md to create:
#   - .header.html: Contains only the top-level header (first '# Header' section)
#   - .readme.html: Full README content excluding the '## Files' section.
#   All content is processed through `b4markdown`.

readonly README="README.md"
readonly HEADER_OUT=".header.html"
readonly README_OUT=".readme.html"

export LC_ALL=C

MARKDOWN="${MARDKDOWN:-b4markdown}"

if [[ ! -f $README ]]; then
    print -u2 "❌ Error: $README not found. Cannot proceed."
    exit 1
fi

if ! command -v $MARKDOWN >/dev/null 2>&1; then
    print -u2 "❌ Error: $MARKDOWN not found in PATH."
    print -u2 "📦 Please install it before running this script."
    print -u2 "⚙️  Alternatively, set MARKDOWN=<your markdown2html> filter>"
    exit 1
fi

create_header=false
print -u2 "🌵 ${0##*/} $@"
for p 
do
    case "$p" in
        --create-header|--create_header)
            create_header=true
            print -u2 "🌻 creating complete html header"
            ;;
    esac
done

MARKDOWN_CSS="${MARKDOWN_CSS:-/.markdown.css}"

# ✂️ Extract header section and strip leading/trailing spaces and '#' chars
d=`pwd`
dirname=`basename $d`
awk -vf="$HEADER_OUT" -vcreate_header=$create_header -vmarkdowncss="$MARKDOWN_CSS" -vdirname="$dirname" '
    BEGIN { in_header = 1
        if ( create_header == "true" ) {
            print("<!DOCTYPE html>");
            print("<html lang=\x27en\x27>")
            print("<head>");
            print(" <title>" dirname "</title>")
            print(" <link rel=\x27stylesheet\x27 href=\x27" markdowncss "\x27 type=\x27text/css\x27>")
            print(" </head>")
            print(" <body>")
        }
        print("<!-- 🚧✨ This file " f " was generated by AutoReadme ✨🚧 -->")
    }
    in_header {
        gsub(/^#+[ \t]*|[ \t]*#+$/, "", $0)
        print("<pre><b>" $0 "</b></pre>")
        in_header = 0
    }
' "$README" > "$HEADER_OUT"

# 📤 Extract everything before the '## Files' section
(
print "<!-- 🚧✨ This file $README_OUT was generated by AutoReadme ✨🚧 -->"
awk '
    BEGIN { in_body = 1 }
    /^## Files/ { in_body = 0 }
    in_body { print }
' "$README" | $MARKDOWN 
print ""

# 🖼️ Add any Images if they exist
if [ -f .imageindex ] ; then
  print "<hr size='10' style='background:url(\"/icons/plaid.gif\")' />"
  cat .imageindex 
  rm -f .imageindex # I see not reason to keep this file ....
fi

print "<hr size='10' style='background:url(\"/icons/small/rainbow.gif\")' />" ) > "$README_OUT"

print "✅ Success: $HEADER_OUT and $README_OUT created from $README using b4markdown ✨"

