#!/usr/bin/ksh93
# 🌵 autoreadme — Qutopia: terminal art and philosophical wisdom
# 📦 Part of: https://github.com/wkaefer/autoreadme
# ⚠️  Edit in the autoreadme repo to avoid drift.
#
# A fleeting glimpse of terminal wisdom before reality asserts dominance.

set -e
clear
hr

QUTOPIA_DIR="$HOME/.local/share/qutopia/qutopia"
CRASH_LOG="$HOME/.local/share/qutopia/qutopia_crash.log"

# Check chafa
if ! command -v chafa >/dev/null 2>&1; then
    print "🔴 chafa not found. Qutopia cannot render qutopia without it."
    exit 1
fi

# Get a random qutopia image
integer -a QUTOPIA_LIST
set -A QUTOPIA_LIST -- $(find "$QUTOPIA_DIR" -type f \( -iname "*.png" -o -iname "*.jpg" \))

if (( ${#QUTOPIA_LIST[@]} == 0 )); then
    print "❌ No qutopia images found in $QUTOPIA_DIR"
    print "Please add some .png or .jpg files to keep the illusion alive."
    # exit 1
else
    QUTOPIA_IMG="${QUTOPIA_LIST[RANDOM % ${#QUTOPIA_LIST[@]}]}"
fi

function display_maxim_box {
    typeset -A fg_colors=(
        [red]=31 [green]=32 [yellow]=33 [blue]=34
        [magenta]=35 [cyan]=36 [white]=37
    )

    typeset -a keys=( ${!fg_colors[@]} )
    typeset key=${keys[RANDOM % ${#keys[@]}]}
    typeset fg=${fg_colors[$key]}
    typeset bg="40"  # Black Background
    typeset style="\033[1;${fg};${bg}m"
    typeset reset="\033[0m"

    typeset maxim_line="$1"
    typeset len=${#maxim_line}
    typeset dashes="$(printf '─%.0s' {1..100})"
    typeset border_top="┌${dashes:0:len+2}┐"
    typeset border_bottom="└${dashes:0:len+2}┘"

    print
    print "$style$border_top$reset"
    print "$style│ $maxim_line │$reset"
    print "$style$border_bottom$reset"
    print
}


