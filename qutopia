#   print "\n🔮 Crystal Ball says: \"${messages[RANDOM % ${#messages[@]}]}\""
#   print "\n  ${messages[RANDOM % ${#messages[@]}]}\n"
    display_maxim_box "${messages[RANDOM % ${#messages[@]}]}"
}

# Opening sequence
print "🌌 Initializing Qutopia Terminal Interface..."
sleep 0.5
print "🧰 Assembling minimalist tools... [OK]"
sleep 0.5
print "📚 Preloading infinite knowledge... [OK]"
sleep 0.5
print "🫖 Brewing enlightenment... 💡 [OK]"
sleep 0.5
print "📸 Rendering Qutopia...🌊 "
sleep 0.5

# Fallback ANSI art when no qutopia images are found
function fallback_qutopia_art {
    typeset -a palette=(
        "\033[48;5;197m " "\033[48;5;201m " "\033[48;5;198m "
        "\033[48;5;129m " "\033[48;5;93m " "\033[48;5;127m "
        "\033[48;5;161m " "\033[48;5;177m " "\033[48;5;225m "
    )

    print "\n🎭 No qutopia found. Rendering fallback...\n"
    sleep 1

    for i in {1..10}; do
        line=""
        for j in {1..30}; do
            color=${palette[RANDOM % ${#palette[@]}]}
            line+="${color}█"
        done
        print "${line}\033[0m"
    done
    print
}

# Show the qutopia image
#hafa --fill --symbols=block "$QUTOPIA_IMG"
if [ -f "$QUTOPIA_IMG" ] ; then
	chafa        --symbols=block --size=80% "$QUTOPIA_IMG"
	case "$hostname" in
		Shazam) fallback_qutopia_art;;
	esac
else
	fallback_qutopia_art
fi
sleep 0.5
print "🕰 Welcome to Qutopia"
sleep 0.5
crystal_ball
sleep 3
hr -m box -c -l 2
print "💔 Fragmentation Detected: Idealism leaking into reality."
sleep 0.5
print "⛈  Emotional kernel panic: Cannot sustain perfection in current environment."
sleep 0.5
print "⚰  Terminating Qutopia instance..."
sleep 0.5

# Write crash log
mkdir -p "$(dirname "$CRASH_LOG")"
cat > "$CRASH_LOG" <<EOF
[Qutopia Crash Log]
Date: $(date)
Uptime: $(uptime)
Qutopia File: $(basename "$QUTOPIA_IMG")
Reason: Reality could not maintain structural integrity in the presence of idealized states.
Action Taken: Session forcibly ended to preserve sanity.
Suggested Fix: Lower your standards. Or run Qutopia again.
EOF

print "📝 Crash report saved to $CRASH_LOG"
hr --theme flowers -b
sed 's/^/🧜‍♀️ /' ~/.local/share/qutopia/qutopia_crash.log

# Kill script ungracefully
trap '' TERM INT
kill -9 $$

