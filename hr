#!/bin/bash
# --- Defaults ---
char_mode=ascii
emojis=""
toggle_fg=false
toggle_bg=false
use_bg=true
use_fg=true
output_str=""
line_multiplier=1
text=""
emoji_pad=0
fg=33
bg=42
istty=false

# --- Help Function ---
show_help() {
    cat << EOF
Usage: $0 [options]

Options:
  -e, --emoji      Emoji sequence (comma-separated). Default: рЯМА
  -c, --color      Enable random ANSI foreground colors
  -z, --back       Enable random ANSI background colors
  -f, --fg         Enable foreground color
  -b, --bg         Enable background color
  -n, --no_color   Disable all Color
  -m, --mode       Character mode: ascii (default), emoji, box, card
  -l, --lines      Number of horizontal rule lines to draw

  --list-themes    Display all available theme names
  -T, --theme      Use a named emoji theme (overrides -e)
                   Options:
                     mythical, flowers, succulents, veggies, fruits, trees,
                     random (picks any theme at runtime),
                     cosmic, birds, catsdogs, food
  --tty            Terminal is a tty, even if it tests as not.
  -t               Run sample test
  -h, --help       Show this help message

Examples:
  $0 -e "рЯМИ,рЯМК,вЬ®" -c -b
  $0 -m box -l 2
  $0 -m card --color

Example Emoji Sequences:
  Mythical:    -e "рЯІЬвАНвЩАпЄП,рЯІЭвАНвЩВпЄП,рЯІЪ,рЯІЮвАНвЩВпЄП,рЯІЫвАНвЩАпЄП,рЯІЩвАНвЩАпЄП"
  Flowers:     -e "рЯМЄ,рЯМЉ,рЯМє,рЯМЈ,рЯТР,рЯМЇ"
  Succulents:  -e "рЯМµ,рЯ™і,рЯМ±,рЯМњ,рЯНА,рЯ™ї"
  Veggies:     -e "рЯ•Х,рЯМљ,рЯ•ђ,рЯІД,рЯІЕ,рЯ•Т,рЯ•¶"
  Fruits:      -e "рЯНУ,рЯНЙ,рЯНМ,рЯНН,рЯНТ,рЯНЗ,рЯНС"
  Trees:       -e "рЯМ≥,рЯМ≤,рЯМі,рЯ™µ,рЯНГ,рЯНВ"
  Cosmic:      -e "рЯММ,рЯМ†,в≠Р,вЬ®,рЯФЃ,рЯ™Р"

Environment Variable Support:
  HR=eb  рЯЯ¶   HR=eg  рЯЯ©  
  HR=er  рЯЯ•   HR=ey  рЯЯ®  
  HR=et  рЯЪВ   HR=ee  рЯСА 
  HR=C HR=M HR=B HR=R HR=Y HR=G

Note: Command-line arguments take precedence over the HR variable.
EOF
    exit 0
}

# --- Get terminal width ---
if [ -t 1 ] ; then
    term_width=$(tput cols)
else
    term_width=80
fi

fgcolors=(31 32 33 34 35 36 37 38)
bgcolors=(41 42 43 44 45 46 47 48)

# --- Theme shortcuts ---
declare -A THEMES=(
    [mythical]="рЯІЬвАНвЩАпЄП,рЯІЭвАНвЩВпЄП,рЯІЪ,рЯІЮвАНвЩВпЄП,рЯІЫвАНвЩАпЄП,рЯІЩвАНвЩАпЄП"
    [flowers]="рЯМЄ,рЯМЉ,рЯМє,рЯМЈ,рЯТР,рЯМЇ"
    [succulents]="рЯМµ,рЯ™і,рЯМ±,рЯМњ,рЯНА,рЯ™ї"
    [veggies]="рЯ•Х,рЯМљ,рЯ•ђ,рЯІД,рЯІЕ,рЯ•Т,рЯ•¶,рЯНЕ,рЯНЖ"
    [fruits]="рЯНУ,рЯНЙ,рЯНМ,рЯНН,рЯНТ,рЯНЗ,рЯНС"
    [trees]="рЯМ≥,рЯМ≤,рЯМі,рЯ™µ,рЯНГ,рЯНВ"
    [cosmic]="рЯММ,рЯМ†,в≠Р,вЬ®,рЯФЃ,рЯ™Р"
    [birds]="рЯ¶Й,рЯ¶Е,рЯХКпЄП,рЯ¶Ь,рЯР¶,рЯ¶Ґ,рЯРІ"
    [catsdogs]="рЯР±,рЯРґ,рЯРЊ,рЯШЇ,рЯШЄ,рЯШї"
    [food]="рЯНХ,рЯНФ,рЯМЃ,рЯН£,рЯН©,рЯН™"
    [weather]="вША,вЫЕ,вЭД"
    [hearts]="вЭ§,рЯТХ,рЯТЦ"
    [tools]="рЯФІ,рЯФ®"
    [faces]="рЯША,рЯШЃ,рЯШЬ"
)

function no_color
{
	use_fg=false
	use_bg=false
	toggle_fg=false
	toggle_bg=false
}

# --- Abbreviation-aware flag parsing ---
while [[ "$#" -gt 0 ]]; do
    case "$1" in
	-e|--emoji) char_mode="emoji";no_color;emojis="${2:-рЯМА}"; shift ;;
        -c|--color) toggle_fg=true;use_fg=true;;
        -z|--back) toggle_bg=true;use_bg=true;;
        -f|--fg) use_fg=true;;
        -b|--bg) use_bg=true;;
        -m|--mode) char_mode="${2:-ascii}";no_color;shift;;
        -l|--lines) line_multiplier="${2:-1}"; shift ;;

	-n|--nocolor) no_color ;;

        --list-themes)
            echo "Available themes:"
            for key in "${!THEMES[@]}"; do
                echo "  $key: ${THEMES[$key]}"
            done
            exit 0
            ;;

        -T|--theme)

	    char_mode=emoji
	    no_color
        typeset -l _theme_="$2"
            if [[ "$_theme_" == "random" ]]; then
                keys=("${!THEMES[@]}")
                rand_index=$((RANDOM % ${#keys[@]}))
                chosen="${keys[$rand_index]}"
                emojis="${THEMES[$chosen]}"
            elif [[ -n "${THEMES[$_theme_]}" ]]; then
                emojis="${THEMES[$_theme_]}"
            else
                echo "Unknown theme: $2"
                exit 1
            fi

            shift ;;

    --tty)    istty=true;;
	-t)	# ToDo: Change to add Command as Text, maybe an option
		hr 
		hr -e
		HR=C ./hr
		HR=C ./hr Hello
		HR=M ./hr
		HR=G ./hr
		HR=B ./hr
		HR=R ./hr
		HR=Y ./hr
		HR=et ./hr 
		HR=et ./hr  -l 2
		hr -e "рЯМИ,рЯМК,вЬ®" -c 
		hr -e "рЯМИ,рЯМК,вЬ®" -c this is a test
		hr -e "рЯМИ,рЯМК,вЬ®" -c -z
		hr -m box -l 2
		hr -m box -l 2 -c 
		hr -m box -l 2 -c -b
		hr -m card --color
		hr --theme flowers -l 1
		hr --theme flowers -l 2 -z
		hr --theme flowers -l 1 -b
		hr --theme mythical
		hr --theme flowers
		hr --theme succulents
		hr --theme veggies
		hr --theme fruits
		hr --theme trees
		hr --theme cosmic
		HR=eg hr
		exit 0
		;;

        -h|--help) show_help ;;

	*) text=" $@";break;;
	
    esac
    shift
done
text=$(echo "$text" | sed 's/[[:space:]]*$//')

# --- HR environment variable fallback AFTER CLI parsing ---
if [[ "$emojis" == "" && -n "$HR" ]]; then
    case "$HR" in
        eb) char_mode=emoji;no_color;emojis="рЯЯ¶" ;;
        eg) char_mode=emoji;no_color;emojis="рЯЯ©" ;;
        ee) char_mode=emoji;no_color;emojis="рЯСА" ;;
        er) char_mode=emoji;no_color;emojis="рЯЯ•" ;;
        et) char_mode=emoji;no_color;emojis="рЯЪВ" ;;
        ey) char_mode=emoji;no_color;emojis="рЯЯ®" ;;
	C)	fg=33;bg=46;;
        M|P)	fg=33;bg=45;;
	B)	fg=33;bg=44;;
	Y)	fg=33;bg=43;;
	R)	fg=33;bg=41;;
	*)	fg=33;bg=42;;
    esac
fi

# --- Define character sets ---
IFS=',' read -ra EMOJI_ARR <<< "$emojis"
BOX_CHARS=( "вФА" "вФБ" "вФВ" "вФГ" "вФД" "вФЕ" "вФЖ" "вФЗ" "вФИ" "вФЙ" "вФК" "вФЛ" "вХі" "вХµ" "вХґ" "вХЈ" )
CARD_CHARS=( рЯВ° рЯВҐ рЯВ£ рЯВ§ рЯВ• рЯВ¶ рЯВІ рЯВ® рЯВ© рЯВ™ рЯВЂ рЯВ≠ рЯВЃ рЯГБ рЯГВ рЯГГ рЯГД рЯГЕ рЯГЖ рЯГЗ рЯГИ рЯГЙ рЯГК рЯГЛ рЯГН рЯГО )

get_random_char() {
    # Default pattern alternates between / and \ if using emoji mode and default emoji
    if [[ "$char_mode" == "ascii" && "$emojis" == "" ]]; then
        if (( i % 2 == 0 )); then
            echo "/"
        else
            echo "\\\\"
        fi
        return
    fi

    case "$char_mode" in
        box)
            (( ${#BOX_CHARS[@]} == 0 )) && echo -n "#" || echo -n "${BOX_CHARS[$RANDOM % ${#BOX_CHARS[@]}]}"
            ;;
        card)
            (( ${#CARD_CHARS[@]} == 0 )) && echo -n "#" || echo -n "${CARD_CHARS[$RANDOM % ${#CARD_CHARS[@]}]}"
            ;;
        emoji|*)
            (( ${#EMOJI_ARR[@]} == 0 )) && echo -n "#" || echo -n "${EMOJI_ARR[$RANDOM % ${#EMOJI_ARR[@]}]}"
            ;;
    esac
}


# --- Adjust ANSI logic if not a TTY ---
if ! $istty ; then
    if [[ ! -t 1 ]]; then
        toggle_fg=false
        toggle_bg=false
        use_bg=false
        use_fg=false
    fi
fi


# Adjust terminal width for emoji spacing
text_width=${#text}
(( full_term_width=term_width ))
(( partial_term_width = term_width - text_width ))
case "$char_mode" in
	emoji)	(( full_term_width = ( term_width + 1 ) / 2 )) 
		(( partial_term_width = ( term_width + 1 - text_width ) / 2 ))
		(( emoji_pad = ( term_width + 1 - text_width ) % 2 ))
		(( emoji_pad_full = ( term_width + 1 ) % 2 ))
		;;
	box)	(( full_term_width = full_term_width -1 ))
		(( partial_term_width = partial_term_width - 1 ))
		;;
	cards)	(( full_term_width = full_term_width -1 ))
		(( partial_term_width = partial_term_width - 1 ))
		;;
	*)	(( partial_term_width = partial_term_width - 1 ))
		;;
esac
#echo cm=$char_mode term_width=$term_width text_width=$text_width ftw=$full_term_width ptw=$partial_term_width

# --- Generate bordered rule ---
if [ $line_multiplier -gt 1 ] ; then
(( almost_the_last_line=line_multiplier-1 ))
for ((line=0; line<almost_the_last_line; line++)); do
    output_str+="#"
    for ((i=1; i<full_term_width-1; i++)); do
        char=$(get_random_char)
        if $toggle_fg; then
            fg=${fgcolors[$(( RANDOM % ${#fgcolors[@]} ))]}
	fi
	if $toggle_bg; then
            bg=${bgcolors[$(( RANDOM % ${#bgcolors[@]} ))]}
	fi

        if $use_bg; then
	    if $use_fg; then
		output_str+="\e[1;${fg};${bg}m$char\e[0m"
            else
                output_str+="\e[1;${bg}m$char\e[0m"
            fi
	elif $use_fg; then
            output_str+="\e[1;${fg}m$char\e[0m"
        else
            output_str+="$char"
        fi
    done
    output_str+=" $(printf '%*s' $emoji_pad_full '')#\n"
done
fi

output_str+="#"
for ((i=1; i<partial_term_width-1; i++)); do
    char=$(get_random_char)
    if $toggle_fg; then
        fg=${fgcolors[$(( RANDOM % ${#fgcolors[@]} ))]}
	fi
	if $toggle_bg; then
        bg=${bgcolors[$(( RANDOM % ${#bgcolors[@]} ))]}
	fi

    if $use_bg; then
	if $use_fg; then
		output_str+="\e[1;${fg};${bg}m$char\e[0m"
        else
            output_str+="\e[1;${bg}m$char\e[0m"
        fi
	elif $use_fg; then
        output_str+="\e[1;${fg}m$char\e[0m"
    else
        output_str+="$char"
    fi
done
output_str+="$text $(printf '%*s' $emoji_pad '')#\n"
echo -ne "$output_str"
