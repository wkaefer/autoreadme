#/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/**--__
	# Auto-insert blank line before lists (Option C — see b4markdown)
	# markdown_py (CommonMark) requires a blank line before a list. When
	# authors omit it after a label like "**What it does:**" followed by
	# "1. ..." or "- ...", the list collapses into the preceding paragraph.
	# This filter inserts the missing blank line. Skips fenced code blocks.
	awk '
		BEGIN { in_fence = 0; prev = ""; prev_blank = 1 }

		/^[[:space:]]*(```|~~~)/ {
			in_fence = !in_fence
			print
			prev = $0
			prev_blank = 0
			next
		}

		in_fence {
			print
			prev = $0
			prev_blank = 0
			next
		}

		{
			is_list         = ($0   ~ /^[[:space:]]*([0-9]+\.|[-*+])[[:space:]]+/)
			is_blank        = ($0   ~ /^[[:space:]]*$/)
			prev_is_list    = (prev ~ /^[[:space:]]*([0-9]+\.|[-*+])[[:space:]]+/)
			prev_is_heading = (prev ~ /^#+[[:space:]]/)

			if (is_list && !prev_blank && !prev_is_list && !prev_is_heading) {
				print ""
			}

			print
			prev = $0
			prev_blank = is_blank
		}
	' |
#/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/**--__
	markdown_py --encoding utf-8 -x extra |

    # Mermaid Fixup
    awk '
        BEGIN { in_mermaid = 0; mermaid_included = 0; }
        # Match mermaid start block
        /^<pre><code class="language-mermaid">/ {
            if ( mermaid_included == 0 ) {
                print("<script src=\x27/.js/mermaid.min.js\x27></script>")
                print("<script>")
                print("  mermaid.initialize({ startOnLoad: true })")
                print("</script>")
                mermaid_included = 1;
            }
            sub(/^<pre><code class="language-mermaid">/, "<pre><code><div class=\"mermaid\">")
            print 
            in_mermaid = 1
            next
        }
        # Match end block
        /^<\/code><\/pre>$/ {
            if (in_mermaid) {
                print "</div>" $0
                in_mermaid = 0
                next
            }
        }
        # Default: print unchanged
        { print }' |

#/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/**--__
