#/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/**--__
	awk '
	# State | Pattern1 | Pattern2  | Not-Pattern || Action
	#     1 |   Yes    |           |             || A1
	#     1 |          |   Yes     |             || A2
	#     1 |          |           |    Yes      || A2
	#     2 |   Yes    |           |             || A3
	#     2 |          |   Yes     |             || A4
	#     2 |          |           |    Yes      || A3
	#     3 |   Yes    |           |             || A5
	#     3 |          |   Yes     |             || A3
	#     3 |          |           |    Yes      || A3
	# Action:
	#	A1 - queue(pattern), state=2
	#	A2 - print, state=1
	#	A3 - purge(print), print,state=1
	#	A4 - queue(pattern), state=3
	#	A5 - comment(queue),print,state=1

	function fqueue(p) { queue[qcounter++]=p; }
	function fpurge()  { for ( i = 1; i < qcounter; i++ ) { print(queue[i]); delete queue[i]; } qcounter=1; }
	function dpurge()  { print "<!-- ";
                             # print qcounter;
			     for ( i = 1; i < qcounter; i++ ) { print(queue[i]); delete queue[i]; }
			     qcounter=1;
			     print "-->";}

	BEGIN {
		state=0;
		qcounter=1;
		machine[1,1] = 1;  machine[1,2] = 2;  machine[1,3] = 2;
		machine[2,1] = 3;  machine[2,2] = 4;  machine[2,3] = 3;
		machine[3,1] = 5;  machine[3,2] = 3;  machine[3,3] = 3;
	}

	{ klass=2 }
	/^<p><strong>User:<\/strong><\/p>/      {  klass=1 }
	/^<p><strong>Assistant:<\/strong><\/p>/ {  klass=1 }
	/^<p><strong>Tool:<\/strong><\/p>/      {  klass=1 }
	/^<hr \/>/                              {  klass=2 }

	{ 
		switch(machine[state,klass]) {
			case 1:	fqueue($0);
				state=2;
				break;
			case 2:	print;
				state=1;
				break;
			case 3:	fpurge();
				print
				state=1;
				break;
			case 4:	fqueue($0);
				state=3
				break;
			case 5:	dpurge();
				print;
				state=1;
				break;
			default:
				print;
				state=1;
				break;
		}
	}
	' |
#/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/**--__
	awk '
	function fqueue(p) { queue[qcounter++]=p; }
	function fpurge()  { for ( i = 1; i < qcounter; i++ ) { print(queue[i]); delete queue[i]; } qcounter=1; }
	function dpurge()  { print "<!-- ";
                             # print qcounter;
			     for ( i = 1; i < qcounter; i++ ) { print(".... " queue[i]); delete queue[i]; }
			     qcounter=1;
			     print "-->";}
	BEGIN {
		skip=0;
    		qcounter=1;
	}

	/^<p><strong>Tool:<\/strong><\/p>/ {
		fqueue($0)
		skip=1
		next
	}

	/^<p>DALL.*E displayed 1 images\./ {
    		if (skip==1) {
			skip++
			fqueue($0)
			next  # Continue skipping
		}
	}

	/^<hr \/>/ {
		if (skip==2) {
			fqueue($0)
			skip = 0  # Stop skipping after this line
			dpurge()
        		next
    		}
	}

	qcounter > 3 {
		print("<-- qcounter=" qcounter " -->")
		skip=0;
	
	}

	{
		fpurge()
    		print  # Print everything else
	}' |
#/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/\/**--__
