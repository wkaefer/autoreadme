	gawk '
		@load "filefuncs"  # Load the file functions extension
		{
		if ( $0 ~ /^<p>{\x27content_type\x27: \x27image_asset_pointer\x27, \x27asset_pointer\x27: \x27file-service:\x2f\x2f/ ) {
