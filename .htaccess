# 🛡️ Ignore sensitive files
<Files ~ "^.backups$">
  Require all denied
</Files>
<Files ~ "^.git$">
  Require all denied
</Files>
<Files ~ "^..netrc$">
  Require all denied
</Files>
<Files ~ "^.netrc$">
  Require all denied
</Files>
<Files ~ "^.ssh$">
  Require all denied
</Files>
<Files ~ "^Downloads$">
  Require all denied
</Files>
<Files ~ "^.backups$">
  Require all denied
</Files>
<Files ~ "^notfolder.jpg$">
  Require all denied
</Files>
<Files ~ "\*.a$">
  Require all denied
</Files>
<Files ~ "\*.o$">
  Require all denied
</Files>
<Files ~ "\*.so$">
  Require all denied
</Files>
<Files ~ "\*.bak$">
  Require all denied
</Files>

