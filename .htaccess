  Require all denied
</Files>
<Files ~ "^notfolder.jpg$">
  Require all denied
</Files>
<Files ~ "\*.a$">
  Require all denied
</Files>
<Files ~ "\*.o$">
  Require all denied
</Files>
<Files ~ "\.so$">
  Require all denied
</Files>

