def get_mime_emoji(mime_type):
    if not mime_type:
        return '❓'
    
    # Specific mappings first
    mime_to_emoji = {
        'text/plain': '📄',
        "text/x-makefile": "🚂",
        'image/ico': '🖼',
        'image/gif': '🖼',
        'image/jpeg': '🖼',
        'image/jpeg': '🖼',
        'image/webp': '🖼',
        'application/pdf': '📄',
        'application/zip': '📦',
        'application/x-executable': '🔨',
        'application/x-shellscript': '🔩',
        'inode/directory': '📁',
        'inode/symlink': '🔗',
        'application/json': '🔢',
        'text/html': '🌐',
        'text/x-script.python': '🐍',
        'text/x-python': '🐍',
        'text/x-python3': '🐍',
        'application/octet-stream': '📦',
    }
    
    if mime_type in mime_to_emoji:
        return mime_to_emoji[mime_type]
    
    # Generic fallback
    main_type = mime_type.split('/')[0]
    return {
        "image": "🖼️",
        "text": "📄",
        "application": "📦"
    }.get(main_type, '❓')

def get_description(path):
    descriptions = {
        "makefile":     "Instructions",
        "README":       "Project overview",
        "README.md":    "Project overview (Markdown)",
        "license":      "License information",
        ".gitignore":   "Git ignore rules",
        ".htaccess":    "Apache config",
        ".json":        "JSON data",
        ".py":          "Python script",
        ".sh":          "Shell script",
        ".md":          "Markdown file",
        ".txt":         "Text document"
        # add more as needed
    }
    name = os.path.basename(path)
    key = name.lower()
    # Exact match, then by extension
    if key in descriptions:
        return descriptions[key]
    for ext in descriptions:
        if key.endswith(ext):
            return descriptions[ext]
    return ""

def get_mime_type(path):
    verbose(" get_mime_type("+path+")")
    mime_type, _ = mimetypes.guess_type(path)
    if not mime_type:
        try:
            verbose("  xdg-mime query filetype "+path+"")
            result = subprocess.run(
                ['xdg-mime','query','filetype', path ],
                capture_output = True,
                text=True,
                check=True
            )
            mime_type = result.stdout.strip()
            verbose(f"MIME type: {mime_type}")
        except Exception:
            try:
                verbose("   file --mime-type -b "+path+"")
                result = subprocess.run(
                    ['file', '--mime-type', '-b', path],
                    capture_output=True,
                    text=True,
                    check=True
                )
                mime_type = result.stdout.strip()
                verbose(f"MIME type: {mime_type}")
            except Exception:
                mime_type = None
    return mime_type

def pick_emoji(path):
    verbose("pick_emoji("+path+")")
    basename = os.path.basename(path).lower()
    if os.path.islink(path):
        return "🔗"
    if os.path.isdir(path):
        return "📁"
    for key, emoji in EMOJI_MAP.items():
        if basename.endswith(key):
            return emoji
    for key, emoji in EMOJI_MAP2.items():
        if key == basename:
            return emoji
    mime_type = get_mime_type(path)
    if mime_type:
        # print(mime_type)
        return get_mime_emoji(mime_type)
    return

