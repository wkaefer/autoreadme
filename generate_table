# Files to ignore in the generated output
from ignore_list import IGNORE_LIST

def get_git_ignored_files():
    try:
        result = subprocess.run(
            # ToDo: Can't seem to escape the depths without using find
            # ToDo: Why not use git check-ignore like in checkreadme ?
            # ["git", "ls-files", "--others", "-i", "--exclude-standard"],
            ["git", "ls-files", "-o", "-i", "--exclude-standard", "--directory" ], # -- ':./*' ':(exclude):./*/*'
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            check=True,
            text=True
        )

        # return set(result.stdout.splitlines())
        paths = set()
        for line in result.stdout.splitlines():
            line = line.strip()
            if not line:
                continue
            if line.endswith(("/", "@")):
                line = line[:-1]
            paths.add(line)
            verbose("ignore "+line)
        return paths
    except subprocess.CalledProcessError:
        return set()

GIT_IGNORED_FILES = get_git_ignored_files()

def is_ignored(path):
    basename = os.path.basename(path)
    rel_path = os.path.relpath(path, start=os.getcwd())
    return basename in IGNORE_LIST or rel_path in GIT_IGNORED_FILES


