def center_emoji(emoji, width=3):
    # Assuming emoji and placeholder have the same width
    placeholder = "X"  # Placeholder character
    total_padding = width - len(placeholder)
    padding_left = total_padding // 2
    padding_right = total_padding - padding_left
    return f"{' ' * padding_left}{placeholder}{' ' * padding_right}".replace(placeholder, emoji)

def display_width(s):
    """Display width of a string, accounting for wide/emoji characters."""
    w = 0
    for ch in s:
        eaw = unicodedata.east_asian_width(ch)
        if eaw in ('W', 'F'):
            w += 2
        elif unicodedata.category(ch) in ('Mn', 'Me', 'Cf'):
            pass
        else:
            w += 1
    return w

def ljust_wide(s, width):
    """Left-justify string to target display width."""
    pad = width - display_width(s)
    return s + ' ' * max(pad, 0)

def format_table(entries):
    max_name_len = max(display_width(name) for name, _ in entries) + 2
    name_col = max(max_name_len, 20)
    emoji_col = 4
    total_width = name_col + emoji_col + 3 + 1 + 1  # separators and spaces
    desc_col = max(72 - total_width - 4, 20)  # padding and pipes
    total_width = name_col + emoji_col + desc_col + 6  # final check

    header = f"| {'File'.ljust(name_col)} | 🧿 | {'Description'.ljust(desc_col)} |"
    divider = f"|{'-' * (name_col + 2)}|{'-' * emoji_col}|{'-' * (desc_col + 2)}|"
    rows = [header, divider]

    for name, desc in sorted(entries, key=lambda x: x[0].lower()):
        # Strip trailing / for filesystem lookups
        base = name.rstrip("/")
        # Use get_description if desc is empty
        if not desc:
            desc = get_description(base)
        emoji = center_emoji(pick_emoji(base))
        rows.append(f"| {ljust_wide(name, name_col)} |{emoji}| {ljust_wide(desc, desc_col)} |")

    return rows

def main():
    entries = []
    for item in os.listdir("."):
        if item == os.path.basename(__file__):
            continue
        if not is_ignored(item):
            display_name = item + "/" if os.path.isdir(item) and not os.path.islink(item) else item
            entries.append((display_name, ""))
    if not entries:
        print("Empty Directory")
        return
    for line in format_table(entries):
        print(line)

if __name__ == "__main__":
    main()

