#!/usr/bin/env python3

import os
import subprocess
import unicodedata
import re

README_PATH = "README.md"
from ignore_list import IGNORE_LIST

def is_git_ignored(path):
    try:
        result = subprocess.run(["git", "check-ignore", path],
                                capture_output=True, text=True)
        return result.returncode == 0
    except Exception:
        return False

def list_directory_files():
    return sorted([
        f for f in os.listdir(".")
        #f os.path.isfile(f)
        if os.path.exists(f)
        and f not in IGNORE_LIST
        and not is_git_ignored(f)
    ])

def is_blank(text):
    return not unicodedata.normalize("NFKC", text).strip()

def parse_readme_table(path=README_PATH):
    entries = {}
    if not os.path.exists(path):
        return entries

    with open(path, "r") as f:
        lines = f.readlines()

    in_table = False
    for line in lines:
        if line.strip().startswith("| File"):
            in_table = True
            continue
        if "-------" in line.strip():
            continue
        if in_table:
            if not line.strip().startswith("|"):
                break
            parts = [col.strip() for col in line.strip().split("|")[1:-1]]
            # Match columns with possible escaped pipes in the description
            # match = re.match(r'^\|\s*(\S+)\s*\|\s*(\S+)\s*\|\s*((?:[^|\\]|\\.)+)\s*\|$', line.strip())
            # Match rows with optional emoji and possible escaped pipes in the description
            match = re.match(r'^\|\s*(!?\S*)\s*\|\s*(\S*)\s*\|\s*((?:[^|\\]|\\.)+)\s*\|$', line.strip())
            if match:
                filename, emoji, description = match.groups()
                # Replace escaped pipes with actual pipe character
                description = description.replace(r'\|', '|')
                entries[filename] = description
            else:
                print(f"⚠️  Malformed table row: {line.strip()}")
                continue
    return entries

def validate_readme():
    entries = parse_readme_table()
    files = list_directory_files()
    errors = []

    for f in files:
        if f not in entries:
            errors.append(f"⚠️  File '{f}' exists but is not listed in README.md")
        elif is_blank(entries[f]):
            errors.append(f"⚠️  File '{f}' listed in README.md but has empty description")

    for name in entries:
        if name.startswith("!"):
            continue
        # Report if not reported above
        if name not in files:
            normalized = name.lstrip("*")
            if not os.path.exists(normalized) and not is_git_ignored(normalized):
                errors.append(f"❌ File '{name}' listed in README.md but not found")
            if is_blank(entries[name]):
                errors.append(f"⚠️  File '{name}' listed in README.md but has empty description")

    if errors:
        print("checkreadme: issues found:")
        for err in errors:
            print(" -", err)
        return 1
    else:
        print("✅ README.md file table is valid.")
        return 0

if __name__ == "__main__":
    raise SystemExit(validate_readme())
